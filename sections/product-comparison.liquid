{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="product-comparison color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- unless section.settings.heading == blank -%}
      <div class="section-header text-center">
        <h2 class="section-header__title h1">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <div class="product-comparison__wrapper">
      <div class="product-comparison__table-wrapper">
        <table class="product-comparison__table">
          <thead>
            <tr>
              <th class="product-comparison__header product-comparison__header--feature">
                <span class="visually-hidden">Features</span>
              </th>
              {%- for block in section.blocks -%}
                {%- assign product = block.settings.product -%}
                <th class="product-comparison__header product-comparison__header--product">
                  <div class="product-comparison__product-header">
                    {%- if product.featured_media -%}
                      <div class="product-comparison__image">
                        <img src="{{ product.featured_media | image_url: width: 120 }}" 
                             alt="{{ product.featured_media.alt | escape }}"
                             width="120" height="120" loading="lazy">
                      </div>
                    {%- endif -%}
                    
                    <div class="product-comparison__product-info">
                      <h3 class="product-comparison__product-title h5">
                        {{ product.title | default: block.settings.title }}
                      </h3>
                      
                      {%- if product.price -%}
                        <div class="product-comparison__price">
                          <span class="price">
                            {%- render 'price', product: product, use_variant: true -%}
                          </span>
                        </div>
                      {%- endif -%}
                      
                      {%- if section.settings.show_tier_badges and block.settings.tier_badge -%}
                        {% render 'badge', 
                          text: block.settings.tier_badge_text,
                          modifier: 'tier-badge'
                        %}
                      {%- endif -%}
                    </div>
                  </div>
                </th>
              {%- endfor -%}
            </tr>
          </thead>
          <tbody>
            {%- for feature_block in section.settings.features -%}
              <tr class="product-comparison__row">
                <td class="product-comparison__feature">
                  <div class="product-comparison__feature-content">
                    {%- if feature_block.icon -%}
                      <div class="product-comparison__feature-icon">
                        {% render 'icon', icon: feature_block.icon %}
                      </div>
                    {%- endif -%}
                    <span class="product-comparison__feature-text">{{ feature_block.label }}</span>
                  </div>
                </td>
                {%- for block in section.blocks -%}
                  {%- assign feature_value = block.settings[feature_block.id] -%}
                  <td class="product-comparison__cell">
                    {%- case feature_block.type -%}
                      {%- when 'boolean' -%}
                        {%- if feature_value -%}
                          {% render 'icon', icon: 'check', class: 'product-comparison__check' %}
                        {%- else -%}
                          <span class="product-comparison__dash">-</span>
                        {%- endif -%}
                      {%- when 'text' -%}
                        <span class="product-comparison__text">{{ feature_value | escape }}</span>
                      {%- when 'number' -%}
                        <span class="product-comparison__number">{{ feature_value }}</span>
                    {%- endcase -%}
                  </td>
                {%- endfor -%}
              </tr>
            {%- endfor -%}
            
            <tr class="product-comparison__cta-row">
              <td class="product-comparison__feature">
                <span class="visually-hidden">Purchase options</span>
              </td>
              {%- for block in section.blocks -%}
                <td class="product-comparison__cell product-comparison__cell--cta">
                  {%- if block.settings.product -%}
                    {% render 'product-form', 
                      product: block.settings.product,
                      show_pickup_availability: false,
                      button_text: block.settings.button_text
                    %}
                  {%- else -%}
                    <a href="{{ block.settings.button_link }}" class="button button--primary">
                      {{ block.settings.button_text | escape }}
                    </a>
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Comparison",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Our Systems"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_tier_badges",
      "label": "Show tier badges",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        {"value": "accent-1", "label": "Accent 1"},
        {"value": "accent-2", "label": "Accent 2"},
        {"value": "background-1", "label": "Background 1"},
        {"value": "background-2", "label": "Background 2"},
        {"value": "inverse", "label": "Inverse"}
      ]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Used if no product is selected"
        },
        {
          "type": "checkbox",
          "id": "tier_badge",
          "label": "Show tier badge",
          "default": false
        },
        {
          "type": "text",
          "id": "tier_badge_text",
          "label": "Badge text",
          "default": "Most Popular"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Choose This"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link",
          "info": "Used if no product selected"
        },
        {
          "type": "header",
          "content": "Features"
        },
        {
          "type": "checkbox",
          "id": "growing_trays",
          "label": "Growing trays included",
          "default": false
        },
        {
          "type": "text",
          "id": "seed_varieties",
          "label": "Seed varieties",
          "default": "3"
        },
        {
          "type": "checkbox",
          "id": "led_lights",
          "label": "LED grow lights",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "automated_watering",
          "label": "Automated watering",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "mobile_app",
          "label": "Mobile app control",
          "default": false
        },
        {
          "type": "text",
          "id": "harvest_time",
          "label": "Harvest time",
          "default": "7 days"
        },
        {
          "type": "text",
          "id": "capacity",
          "label": "Growing capacity",
          "default": "Small"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Comparison",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "title": "Starter Kit",
            "growing_trays": true,
            "seed_varieties": "3",
            "harvest_time": "7 days",
            "capacity": "Small"
          }
        },
        {
          "type": "product",
          "settings": {
            "title": "7-Day Grow System",
            "tier_badge": true,
            "tier_badge_text": "Most Popular",
            "growing_trays": true,
            "seed_varieties": "6",
            "harvest_time": "7 days",
            "capacity": "Medium"
          }
        },
        {
          "type": "product",
          "settings": {
            "title": "Smart Grow System",
            "growing_trays": true,
            "seed_varieties": "12",
            "led_lights": true,
            "automated_watering": true,
            "mobile_app": true,
            "harvest_time": "5-7 days",
            "capacity": "Large"
          }
        }
      ]
    }
  ]
}
{% endschema %}