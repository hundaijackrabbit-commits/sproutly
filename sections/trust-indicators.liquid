{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="trust-indicators color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- unless section.settings.heading == blank -%}
      <div class="section-header text-center">
        <h2 class="section-header__title h2">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endunless -%}

    <div class="trust-indicators__list">
      {%- for block in section.blocks -%}
        <div class="trust-indicators__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="trust-indicators__icon">
              {% render 'icon', icon: block.settings.icon %}
            </div>
          {%- endif -%}
          
          <div class="trust-indicators__text">
            {{ block.settings.text }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Indicators",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1",
      "options": [
        {"value": "accent-1", "label": "Accent 1"},
        {"value": "accent-2", "label": "Accent 2"},
        {"value": "background-1", "label": "Background 1"},
        {"value": "background-2", "label": "Background 2"},
        {"value": "inverse", "label": "Inverse"}
      ]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "indicator",
      "name": "Trust Indicator",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust indicator text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Indicators",
      "blocks": [
        {
          "type": "indicator",
          "settings": {
            "icon": "check",
            "text": "10,000+ Happy Customers"
          }
        },
        {
          "type": "indicator",
          "settings": {
            "icon": "check",
            "text": "30-Day Money-Back Guarantee"
          }
        },
        {
          "type": "indicator",
          "settings": {
            "icon": "check", 
            "text": "Free Growing Support"
          }
        },
        {
          "type": "indicator",
          "settings": {
            "icon": "check",
            "text": "Fast & Free Shipping"
          }
        }
      ]
    }
  ]
}
{% endschema %}