{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign columns = section.settings.columns_desktop
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_vendor = section.settings.show_vendor
  assign show_rating = section.settings.show_rating
  assign show_quick_add = section.settings.show_quick_add

  if section.settings.product_list != blank
    assign product_recommendations = section.settings.product_list.products
  else
    assign product_recommendations = collections.all.products | where: 'available'
  endif
-%}

{%- if cart.item_count > 0 and product_recommendations.size > 0 -%}
  <div class="cart-upsell gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
    <div class="page-width">
      {%- unless section.settings.heading == blank -%}
        <div class="section-header text-center">
          <h2 class="section-header__title {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
          {%- if section.settings.subheading != blank -%}
            <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endunless -%}

      <div class="cart-upsell__grid">
        <ul class="product-grid contains-card contains-card--product grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ columns }}-col-desktop" role="list">
          {%- assign shown_products = 0 -%}
          {%- for product in product_recommendations -%}
            {%- if shown_products >= products_to_show -%}
              {%- break -%}
            {%- endif -%}
            
            {%- comment -%} Don't recommend products already in cart {%- endcomment -%}
            {%- assign in_cart = false -%}
            {%- for item in cart.items -%}
              {%- if item.product_id == product.id -%}
                {%- assign in_cart = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- unless in_cart -%}
              <li class="grid__item">
                {% render 'product-card',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: show_secondary_image,
                  show_vendor: show_vendor,
                  show_rating: show_rating,
                  show_quick_add: show_quick_add,
                  section_id: section.id
                %}
              </li>
              {%- assign shown_products = shown_products | plus: 1 -%}
            {%- endunless -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- if section.settings.show_view_all and section.settings.view_all_url != blank -%}
        <div class="cart-upsell__view-all center">
          <a href="{{ section.settings.view_all_url }}" class="button button--secondary">
            {{ section.settings.view_all_text | default: 'View all products' }}
          </a>
        </div>
      {%- endif -%}

      {% comment %} App blocks for cart upsell apps {% endcomment %}
      <div class="cart-upsell__app-blocks">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              <div class="cart-upsell__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {%- when 'custom_text' -%}
              <div class="cart-upsell__custom-text rte" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- when 'tier_cta' -%}
              <div class="cart-upsell__tier-cta" {{ block.shopify_attributes }}>
                <div class="cart-upsell__tier-message">
                  <h3>{{ block.settings.title | default: 'Upgrade Your Growing Experience' }}</h3>
                  <p>{{ block.settings.text | default: 'Consider upgrading to our 7-Day Grow System for the best home growing experience.' }}</p>
                  <a href="{{ block.settings.product_url | default: '/products/7-day-grow-system' }}" class="button button--primary">
                    {{ block.settings.button_text | default: 'Upgrade Now' }}
                  </a>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Cart upsell",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "Small"
        },
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h1",
          "label": "Large"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "product_list",
      "label": "Collection",
      "info": "If no collection is selected, products will be chosen automatically"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Number of products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "2",
      "label": "Number of columns on mobile"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating",
      "info": "To display a rating, add a product rating app. [Learn more](https://help.shopify.com/manual/online-store/themes/theme-structure/page-types#product-grid-section-settings)"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "default": true,
      "label": "Show quick add"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "Show 'View all' button"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "'View all' button link"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "'View all' button text",
      "default": "View all products"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Text on dark"
        }
      ],
      "default": "background-2",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "custom_text",
      "name": "Custom text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add custom text to your cart upsell section.</p>"
        }
      ]
    },
    {
      "type": "tier_cta",
      "name": "Tier upgrade CTA",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Upgrade Your Growing Experience"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Consider upgrading to our 7-Day Grow System for the best home growing experience."
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL",
          "default": "/products/7-day-grow-system"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Upgrade Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cart upsell",
      "settings": {
        "heading": "Complete Your Growing Setup",
        "products_to_show": 3,
        "columns_desktop": 3
      }
    }
  ]
}
{% endschema %}