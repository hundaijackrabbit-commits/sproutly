{%- style -%}
  .footer {
    background-color: var(--color-foreground);
    color: white;
    margin-top: auto;
  }

  .footer__inner {
    padding: 4rem 0 2rem;
  }

  .footer__content {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .footer__content {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 4rem;
    }
  }

  .footer__brand {
    margin-bottom: 2rem;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 2.4rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .footer__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 2rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .footer__social-link:hover {
    background-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .footer__column h3 {
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: white;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__link {
    margin-bottom: 1rem;
  }

  .footer__link a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 1.4rem;
    transition: color 0.2s ease;
  }

  .footer__link a:hover {
    color: var(--color-secondary);
  }

  .footer__newsletter {
    background-color: rgba(255, 255, 255, 0.05);
    padding: 2rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .footer__newsletter h3 {
    margin-bottom: 1rem;
  }

  .footer__newsletter p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.5rem;
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    margin-top: 3rem;
    text-align: center;
  }

  .footer__bottom-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .footer__bottom-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer__copyright {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__legal {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .footer__legal a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 1.3rem;
  }

  .footer__legal a:hover {
    color: rgba(255, 255, 255, 0.8);
  }
{%- endstyle -%}

<footer class="footer">
  <div class="page-width">
    <div class="footer__inner">
      <div class="footer__content">
        <div class="footer__brand">
          <a href="{{ routes.root_url }}" class="footer__logo">
            {% render 'icon', icon: 'seed', size: 'large' %}
            {{ shop.name | default: 'Sproutly' }}
          </a>
          
          <p class="footer__description">
            Empowering home growers to cultivate fresh, nutrient-dense microgreens in any space. 
            From seed to harvest in just 7 days.
          </p>

          <div class="footer__social">
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="footer__social-link" target="_blank" rel="noopener">
                {% render 'icon', icon: 'instagram' %}
                <span class="visually-hidden">Instagram</span>
              </a>
            {%- endif -%}
            
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="footer__social-link" target="_blank" rel="noopener">
                {% render 'icon', icon: 'facebook' %}
                <span class="visually-hidden">Facebook</span>
              </a>
            {%- endif -%}
            
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" class="footer__social-link" target="_blank" rel="noopener">
                {% render 'icon', icon: 'twitter' %}
                <span class="visually-hidden">Twitter</span>
              </a>
            {%- endif -%}
            
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" class="footer__social-link" target="_blank" rel="noopener">
                {% render 'icon', icon: 'youtube' %}
                <span class="visually-hidden">YouTube</span>
              </a>
            {%- endif -%}
          </div>
        </div>

        <div class="footer__column">
          <h3>Products</h3>
          <ul class="footer__links">
            <li class="footer__link">
              <a href="/collections/growing-systems">All Growing Systems</a>
            </li>
            <li class="footer__link">
              <a href="/products/sprout-starter">Sprout Starter</a>
            </li>
            <li class="footer__link">
              <a href="/products/7-day-grow-system">7-Day Grow System</a>
            </li>
            <li class="footer__link">
              <a href="/products/smart-grow-pro">Smart Grow Pro</a>
            </li>
            <li class="footer__link">
              <a href="/collections/seeds">Seeds & Supplies</a>
            </li>
          </ul>
        </div>

        <div class="footer__column">
          <h3>Support</h3>
          <ul class="footer__links">
            <li class="footer__link">
              <a href="/pages/how-it-works">How It Works</a>
            </li>
            <li class="footer__link">
              <a href="/pages/growing-guide">Growing Guide</a>
            </li>
            <li class="footer__link">
              <a href="/pages/faq">FAQ</a>
            </li>
            <li class="footer__link">
              <a href="/pages/contact">Contact Us</a>
            </li>
            <li class="footer__link">
              <a href="/pages/shipping">Shipping Info</a>
            </li>
            <li class="footer__link">
              <a href="/pages/returns">Returns</a>
            </li>
          </ul>
        </div>

        <div class="footer__column">
          <h3>Company</h3>
          <ul class="footer__links">
            <li class="footer__link">
              <a href="/pages/about">About Us</a>
            </li>
            <li class="footer__link">
              <a href="/blogs/growing-tips">Growing Tips</a>
            </li>
            <li class="footer__link">
              <a href="/pages/testimonials">Success Stories</a>
            </li>
            <li class="footer__link">
              <a href="/pages/affiliate">Affiliate Program</a>
            </li>
            <li class="footer__link">
              <a href="/pages/wholesale">Wholesale</a>
            </li>
          </ul>
        </div>
      </div>

      <div class="footer__newsletter">
        <h3>Stay Growing</h3>
        <p>Get weekly growing tips, new variety spotlights, and exclusive member discounts.</p>
        
        {% form 'customer', class: 'newsletter-form newsletter-form--footer' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input id="NewsletterForm--footer"
                     type="email"
                     name="contact[email]"
                     class="field__input"
                     value="{{ form.email }}"
                     aria-required="true"
                     autocorrect="off"
                     autocapitalize="off"
                     autocomplete="email"
                     placeholder="Enter your email"
                     required>
              <label class="field__label visually-hidden" for="NewsletterForm--footer">
                Enter your email
              </label>
              <button type="submit" 
                      class="newsletter-form__button field__button button button--primary" 
                      name="commit">
                <span>Subscribe</span>
                {% render 'icon', icon: 'arrow-right' %}
              </button>
            </div>
          </div>
        {% endform %}
      </div>

      <div class="footer__bottom">
        <div class="footer__bottom-content">
          <p class="footer__copyright">
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Sproutly' }}. All rights reserved.
          </p>
          
          <div class="footer__legal">
            <a href="/pages/privacy-policy">Privacy Policy</a>
            <a href="/pages/terms-of-service">Terms of Service</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_description",
      "label": "Footer description",
      "default": "Empowering home growers to cultivate fresh, nutrient-dense microgreens in any space. From seed to harvest in just 7 days."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay Growing"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter description",
      "default": "Get weekly growing tips, new variety spotlights, and exclusive member discounts."
    }
  ]
}
{% endschema %}