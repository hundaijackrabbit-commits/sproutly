{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="email-capture color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="email-capture__wrapper{% if section.settings.layout == 'split' %} email-capture__wrapper--split{% endif %}">
      {%- if section.settings.image != blank and section.settings.layout == 'split' -%}
        <div class="email-capture__image">
          <img src="{{ section.settings.image | image_url: width: 600 }}" 
               alt="{{ section.settings.image.alt | escape }}"
               width="{{ section.settings.image.width }}"
               height="{{ section.settings.image.height }}"
               loading="lazy">
        </div>
      {%- endif -%}

      <div class="email-capture__content{% if section.settings.layout == 'center' %} text-center{% endif %}">
        {%- unless section.settings.heading == blank -%}
          <h2 class="email-capture__heading h1">
            {{ section.settings.heading }}
          </h2>
        {%- endunless -%}
        
        {%- if section.settings.subheading != blank -%}
          <p class="email-capture__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="email-capture__text rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <div class="email-capture__form">
          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input id="NewsletterForm--{{ section.id }}"
                       type="email"
                       name="contact[email]"
                       class="field__input"
                       value="{{ form.email }}"
                       aria-required="true"
                       autocorrect="off"
                       autocapitalize="off"
                       autocomplete="email"
                       {% if form.errors %}
                         autofocus
                         aria-invalid="true"
                         aria-describedby="ContactFooter-error"
                       {% elsif form.posted_successfully? %}
                         aria-describedby="ContactFooter-success"
                       {% endif %}
                       placeholder="{{ section.settings.placeholder | default: 'Email address' }}"
                       required>
                <label class="field__label visually-hidden" for="NewsletterForm--{{ section.id }}">
                  {{ section.settings.placeholder | default: 'Email address' }}
                </label>
                <button type="submit" 
                        class="newsletter-form__button field__button button button--primary" 
                        name="commit" 
                        aria-label="{{ section.settings.button_label | default: 'Subscribe' }}">
                  <span class="newsletter-form__button-text">{{ section.settings.button_label | default: 'Subscribe' }}</span>
                  <span class="newsletter-form__button-icon">
                    {% render 'icon', icon: 'arrow-right' %}
                  </span>
                </button>
              </div>
            </div>
            
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="ContactFooter-error">
                <span class="form-status-icon" aria-hidden="true">{% render 'icon', icon: 'error' %}</span>
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}.
              </small>
            {%- endif -%}
            
            {%- if form.posted_successfully? -%}
              <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>
                <span class="form-status-icon" aria-hidden="true">{% render 'icon', icon: 'success' %}</span>
                {{ section.settings.success_message | default: 'Thanks for subscribing!' }}
              </h3>
            {%- endif -%}
          {% endform %}
        </div>

        {%- if section.settings.benefits != blank -%}
          <div class="email-capture__benefits">
            <ul class="email-capture__benefits-list">
              {%- assign benefits_array = section.settings.benefits | split: ',' -%}
              {%- for benefit in benefits_array -%}
                <li class="email-capture__benefit">
                  {% render 'icon', icon: 'check-small', class: 'email-capture__benefit-icon' %}
                  <span>{{ benefit | strip }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- if section.settings.show_privacy_text -%}
          <div class="email-capture__privacy">
            <p class="email-capture__privacy-text">
              {{ section.settings.privacy_text | default: 'We respect your privacy. Unsubscribe at any time.' }}
            </p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Email Capture",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "center",
      "options": [
        {"value": "center", "label": "Center"},
        {"value": "split", "label": "Split with image"}
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Only displayed when layout is set to 'Split with image'"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Growing Tips & Updates"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join our community of home growers"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "textarea",
      "id": "benefits",
      "label": "Benefits (comma separated)",
      "default": "Weekly growing tips, Exclusive discounts, New variety updates",
      "info": "Comma-separated list of subscriber benefits"
    },
    {
      "type": "checkbox",
      "id": "show_privacy_text",
      "label": "Show privacy text",
      "default": true
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy text",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "accent-1",
      "options": [
        {"value": "accent-1", "label": "Accent 1"},
        {"value": "accent-2", "label": "Accent 2"},
        {"value": "background-1", "label": "Background 1"},
        {"value": "background-2", "label": "Background 2"},
        {"value": "inverse", "label": "Inverse"}
      ]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Email Capture"
    }
  ]
}
{% endschema %}